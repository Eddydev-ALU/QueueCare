                  "const ts = Date.now();",
                  "pm.environment.set('ts', ts);",
                  "pm.environment.set('patient_email', `patient_${ts}@test.com`);",
                  "pm.environment.set('patient_password', 'Test@1234');",
                  "pm.environment.set('patient2_email', `patient2_${ts}@test.com`);",
                  "pm.environment.set('patient2_password', 'Test@1234');",
