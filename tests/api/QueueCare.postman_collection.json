{
  "info": {
    "name": "QueueCare API Tests",
    "_postman_id": "queuecare-api-tests-v1",
    "description": "Full API test suite — Happy Path, Negative Cases, Edge Cases",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const today = new Date();",
          "const fmt = d => d.toISOString().split('T')[0];",
          "const add = n => { const d = new Date(today); d.setDate(today.getDate() + n); return d; };",
          "pm.environment.set('yesterday_date', fmt(add(-1)));",
          "pm.environment.set('future_date_1', fmt(add(30)));",
          "pm.environment.set('future_date_2', fmt(add(31)));",
          "pm.environment.set('future_date_3', fmt(add(32)));",
          "pm.environment.set('future_date_4', fmt(add(33)));",
          "pm.environment.set('future_date_5', fmt(add(34)));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "0. Setup",
      "item": [
