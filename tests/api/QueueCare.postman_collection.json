    {
      "name": "1. Happy Path",
      "item": [
        {
          "name": "HP1 — Register → Login → Valid Token Structure",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('Token is a non-empty string', () => {",
                  "  pm.expect(b.token).to.be.a('string').and.to.have.length.above(20);",
                  "});",
                  "pm.test('User object has required fields', () => {",
                  "  pm.expect(b.user).to.include.keys(['id', 'name', 'email', 'role']);",
                  "});",
                  "pm.test('Role is patient', () => pm.expect(b.user.role).to.eql('patient'));",
                  "pm.test('Token has 3 JWT segments', () => {",
                  "  pm.expect(b.token.split('.').length).to.eql(3);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{patient_email}}\",\"password\":\"{{patient_password}}\"}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "HP2 — Create Appointment → Queue Number Assigned",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.test('Queue number is a positive integer', () => {",
                  "  pm.expect(b.queue_number).to.be.a('number').and.to.be.above(0);",
                  "});",
                  "pm.test('Status is pending', () => pm.expect(b.status).to.eql('pending'));",
                  "pm.test('Doctor matches', () => pm.expect(b.doctor).to.eql(pm.environment.get('doctor_name')));",
                  "pm.test('Date matches', () => pm.expect(b.date).to.eql(pm.environment.get('future_date_1')));",
                  "pm.test('Patient name present', () => pm.expect(b.patient_name).to.be.a('string'));",
                  "pm.environment.set('appointment_id', b.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{patient_token}}", "type": "string"}]},
            "body": {
              "mode": "raw",
              "raw": "{\"doctor\":\"{{doctor_name}}\",\"date\":\"{{future_date_1}}\",\"reason\":\"Annual checkup\"}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/appointments",
              "host": ["{{base_url}}"],
              "path": ["appointments"]
            }
          }
        },
        {
          "name": "HP3a — Fetch All Appointments (Patient sees only own)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const rows = pm.response.json();",
                  "pm.test('Returns an array', () => pm.expect(rows).to.be.an('array'));",
                  "pm.test('All rows belong to this patient', () => {",
                  "  const patientId = parseInt(pm.environment.get('patient_id'));",
                  "  rows.forEach(r => pm.expect(r.patient_id).to.eql(patientId));",
                  "});",
                  "pm.test('Patient 2 appointment not visible', () => {",
                  "  const ids = rows.map(r => r.id);",
                  "  pm.expect(ids).to.not.include(parseInt(pm.environment.get('patient2_appointment_id')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{patient_token}}", "type": "string"}]},
            "url": {
              "raw": "{{base_url}}/appointments",
              "host": ["{{base_url}}"],
              "path": ["appointments"]
            }
          }
        },
        {
          "name": "HP3b — Fetch All Appointments (Staff sees all)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const rows = pm.response.json();",
                  "pm.test('Returns an array', () => pm.expect(rows).to.be.an('array'));",
                  "pm.test('Includes both patients appointments', () => {",
                  "  const ids = rows.map(r => r.id);",
                  "  pm.expect(ids).to.include(parseInt(pm.environment.get('appointment_id')));",
                  "  pm.expect(ids).to.include(parseInt(pm.environment.get('patient2_appointment_id')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "url": {
              "raw": "{{base_url}}/appointments",
              "host": ["{{base_url}}"],
              "path": ["appointments"]
            }
          }
        },
        {
          "name": "HP4 — Fetch Single Appointment by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('ID matches', () => pm.expect(b.id).to.eql(parseInt(pm.environment.get('appointment_id'))));",
                  "pm.test('Has all required fields', () => {",
                  "  pm.expect(b).to.include.keys(['id','patient_id','doctor','date','reason','queue_number','status','patient_name','patient_email']);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{patient_token}}", "type": "string"}]},
            "url": {
              "raw": "{{base_url}}/appointments/{{appointment_id}}",
              "host": ["{{base_url}}"],
              "path": ["appointments", "{{appointment_id}}"]
            }
          }
        },
        {
          "name": "HP5 — Staff Marks Patient Served → Status Updates",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Success message returned', () => {",
                  "  pm.expect(pm.response.json().message).to.include('served');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [],
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "url": {
              "raw": "{{base_url}}/queue/{{appointment_id}}/serve",
              "host": ["{{base_url}}"],
              "path": ["queue", "{{appointment_id}}", "serve"]
            }
          }
        },
        {
          "name": "HP5 verify — Confirm Status is Now Served",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Appointment status is served', () => {",
                  "  pm.expect(pm.response.json().status).to.eql('served');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "url": {
              "raw": "{{base_url}}/appointments/{{appointment_id}}",
              "host": ["{{base_url}}"],
              "path": ["appointments", "{{appointment_id}}"]
            }
          }
        }
      ]
    },
